{
  "config_version": 2,
  "microcontroller_uuid": "00000000-0000-0000-0000-000000000000",
  "provider_uuid": "00000000-0000-0000-0000-000000000000",
  "unit": "kW",
  "provider_has_power_meter": true,
  "provider_has_energy_storage": true,
  "available_sensors": ["ds18b20"],
  "active_low": false,

  "heartbeat_interval": 60,
  "device_max": 2,

  "devices": {
    "1": {
      "device_id": 1,
      "device_uuid": "00000000-0000-0000-0000-000000000001",
      "device_number": 1,
      "mode": "AUTO",
      "rated_power": 2.0,
      "threshold_value": 3.0,
      "threshold_unit": "kW",
      "auto_rule": {
        "operator": "ANY",
        "items": [
          {
            "source": "provider_primary_power",
            "comparator": "gte",
            "value": 3.0,
            "unit": "kW"
          }
        ]
      },
      "desired_state": null,
      "is_on": false
    },
    "2": {
      "device_id": 2,
      "device_uuid": "00000000-0000-0000-0000-000000000002",
      "device_number": 2,
      "mode": "AUTO",
      "rated_power": 2.0,
      "threshold_value": 2.0,
      "threshold_unit": "kW",
      "auto_rule": {
        "operator": "ANY",
        "items": [
          {
            "operator": "ALL",
            "items": [
              {
                "source": "provider_primary_power",
                "comparator": "gte",
                "value": 2.0,
                "unit": "kW"
              },
              {
                "source": "provider_battery_soc",
                "comparator": "gte",
                "value": 30.0,
                "unit": "%"
              }
            ]
          }
        ]
      },
      "desired_state": null,
      "is_on": false
    }
  }
}
